{
  "manifest_version": 3,
  "name": "Light Jira",
  "version": "1.0.0",
  "description": "A fast, lightweight Jira ticket viewer. Works directly from the browser extension — no proxy needed.",
  "permissions": ["tabs", "scripting", "activeTab"],
  "host_permissions": [
    "https://*.atlassian.net/*"
  ],
  "action": {
    "default_popup": "extension/popup.html",
    "default_title": "Light Jira",
    "default_icon": {
      "16": "extension/icons/icon16.png",
      "48": "extension/icons/icon48.png",
      "128": "extension/icons/icon128.png"
    }
  },
  "icons": {
    "16": "extension/icons/icon16.png",
    "48": "extension/icons/icon48.png",
    "128": "extension/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.atlassian.net/*"],
      "js": ["extension/content-jira.js"],
      "run_at": "document_idle"
    }
  ]
}
